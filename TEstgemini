.sec-title{font-size:clamp(26px,3vw,40px);font-weight:700;line-height:1.2;margin-bottom:12px;max-width:800px;}
.sec-title span{color:#FF6B35;}
.sec-intro{font-size:15px;line-height:1.75;color:#444;max-width:720px;margin-bottom:8px;}

h3{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:#bbb;margin:36px 0 12px;}

/* STATS */
.stats{display:flex;gap:2px;margin:32px 0;flex-wrap:wrap;}
