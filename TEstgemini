.ticker .bold{font-weight:800;color:#fff;}
.ticker .dot{color:#333;font-size:8px;}
@keyframes tick{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* HERO */
.hero{
  background:#000;
